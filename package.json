{
  "name": "tholac.skull-king-scorer",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "paraglide": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide",
    "dev": "bun run paraglide && vite dev",
    "build": "bun run paraglide && vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.63.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@types/node": "^25.9.3",
    "@vitest/ui": "^4.1.8",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "svelte": "^5.56.1",
    "svelte-check": "^4.6.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@inlang/paraglide-js": "1",
    "@tailwindcss/vite": "^4.3.0",
    "daisyui": "^5.5.23",
    "peerjs": "^1.5.5",
    "tailwindcss": "^4.3.0"
  }
}
